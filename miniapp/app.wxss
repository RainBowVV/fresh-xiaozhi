/* 鲜小智 - 全局样式 */
page {
  --green-dark: #2d6a4f;
  --green: #40916c;
  --green-light: #52b788;
  --green-pale: #d8f3dc;
  --green-bg: #f0faf4;
  --orange: #e76f51;
  --orange-light: #f4a261;
  --cream: #fefae0;
  --brown: #8b6914;
  --text-primary: #1a1a1a;
  --text-secondary: #666;
  --text-light: #999;
  --bg-page: #f8f5f0;
  --bg-card: #ffffff;
  --border: #eee;
  --shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-page);
  line-height: 1.6;
}

.container {
  padding: 24rpx;
}

/* 卡片 */
.card {
  background: var(--bg-card);
  border-radius: 16rpx;
  box-shadow: var(--shadow);
  overflow: hidden;
}

/* 主按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--green) 0%, var(--green-light) 100%);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  line-height: 1.4;
  transition: all 0.2s;
}

.btn-primary:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn-primary.btn-block {
  display: block;
  width: 100%;
}

.btn-primary.btn-sm {
  padding: 12rpx 32rpx;
  font-size: 26rpx;
}

.btn-primary.btn-orange {
  background: linear-gradient(135deg, var(--orange) 0%, var(--orange-light) 100%);
}

/* 次要按钮 */
.btn-outline {
  background: transparent;
  color: var(--green);
  border: 2rpx solid var(--green);
  border-radius: 48rpx;
  padding: 18rpx 48rpx;
  font-size: 28rpx;
  text-align: center;
  line-height: 1.4;
}

.btn-outline:active {
  background: var(--green-pale);
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-green {
  background: var(--green-pale);
  color: var(--green);
}

.tag-orange {
  background: #ffecd2;
  color: var(--orange);
}

.tag-gray {
  background: #f5f5f5;
  color: var(--text-light);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-state .icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-state .text {
  color: var(--text-light);
  font-size: 28rpx;
}

.empty-state .sub-text {
  color: var(--text-light);
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* 价格 */
.price {
  color: var(--orange);
  font-weight: 700;
}

.price .symbol {
  font-size: 24rpx;
}

.price .amount {
  font-size: 36rpx;
}

.price-sm .symbol {
  font-size: 20rpx;
}

.price-sm .amount {
  font-size: 30rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* 加载状态 */
.loading-more {
  text-align: center;
  padding: 30rpx;
  color: var(--text-light);
  font-size: 24rpx;
}

/* 数量选择器 */
.qty-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1;
}

.qty-btn-minus {
  background: #f5f5f5;
  color: var(--text-secondary);
}

.qty-btn-plus {
  background: var(--green);
  color: #fff;
}

.qty-value {
  min-width: 56rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

/* 底部安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
