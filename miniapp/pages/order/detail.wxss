/* 订单详情页样式 */
.page {
  padding-bottom: 140rpx;
  background: var(--bg-page);
}

/* 状态栏 */
.status-bar {
  padding: 24rpx 32rpx;
}

.status-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.status-bg-0 {
  background: linear-gradient(135deg, var(--orange) 0%, var(--orange-light) 100%);
}

.status-bg-1, .status-bg-2 {
  background: linear-gradient(135deg, var(--green) 0%, var(--green-light) 100%);
}

.status-bg-3 {
  background: linear-gradient(135deg, #1976d2 0%, #42a5f5 100%);
}

.status-bg-4 {
  background: linear-gradient(135deg, var(--green-dark) 0%, var(--green) 100%);
}

.status-bg-5 {
  background: linear-gradient(135deg, #757575 0%, #9e9e9e 100%);
}

.status-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.status-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

/* 通用卡片 */
.section-card {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: var(--shadow);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border);
}

.section-icon {
  font-size: 32rpx;
}

/* 地址信息 */
.address-top {
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.address-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.address-phone {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.address-detail {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 商品项 */
.order-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-name {
  font-size: 26rpx;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-qty {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 订单信息行 */
.info-row {
  display: flex;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
  word-break: break-all;
}

/* 费用行 */
.fee-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.fee-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.fee-value {
  font-size: 26rpx;
  color: var(--text-primary);
}

.fee-value.free {
  color: var(--green);
  font-size: 24rpx;
}

.total-row {
  border-top: 1rpx solid var(--border);
  margin-top: 12rpx;
  padding-top: 20rpx;
}

.total-row .fee-label {
  font-weight: 600;
  color: var(--text-primary);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}

.bottom-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.action-btn {
  padding: 18rpx 40rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  border: 1rpx solid #ddd;
  color: var(--text-secondary);
}

.action-btn.primary {
  background: var(--green);
  color: #fff;
  border-color: var(--green);
  font-weight: 600;
}
