/* 订单列表页样式 */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-page);
}

/* 状态标签栏 */
.status-tabs {
  display: flex;
  background: #fff;
  padding: 0 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  position: relative;
  transition: all 0.2s;
}

.tab-item.active {
  color: var(--green-dark);
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: var(--green);
  border-radius: 3rpx;
}

/* 订单列表 */
.order-list {
  flex: 1;
  padding: 20rpx 32rpx;
  box-sizing: border-box;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-no {
  font-size: 24rpx;
  color: var(--text-light);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.countdown {
  font-size: 24rpx;
  color: #e64340;
  font-weight: 600;
  font-family: monospace;
}

.order-status {
  font-size: 26rpx;
  font-weight: 600;
}

.status-0 { color: var(--orange); }
.status-1 { color: var(--green); }
.status-2 { color: var(--green); }
.status-3 { color: #2196f3; }
.status-4 { color: var(--text-light); }
.status-5 { color: var(--text-light); }

/* 订单商品 */
.order-items {
  padding: 16rpx 24rpx;
}

.order-item {
  display: flex;
  gap: 16rpx;
  padding: 12rpx 0;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-name {
  font-size: 26rpx;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-right {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-qty {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 订单底部 */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f5f5f5;
}

.order-time {
  font-size: 22rpx;
  color: var(--text-light);
}

.order-total {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: var(--text-primary);
}

/* 操作按钮 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 16rpx 24rpx 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.action-btn {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  border: 1rpx solid #ddd;
  color: var(--text-secondary);
}

.action-btn.primary {
  background: var(--green);
  color: #fff;
  border-color: var(--green);
}
