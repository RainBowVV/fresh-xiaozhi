/* 确认订单页样式 */
.page {
  padding-bottom: 140rpx;
  background: var(--bg-page);
}

/* 收货地址 */
.address-card {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 20rpx 24rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  box-shadow: var(--shadow);
  position: relative;
}

.address-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--green) 0%, var(--green-light) 50%, var(--orange-light) 100%);
  border-radius: 16rpx 16rpx 0 0;
}

.address-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.address-phone {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.default-tag {
  font-size: 20rpx;
  color: var(--green);
  background: var(--green-pale);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.address-detail {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.no-address {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.no-address-icon {
  font-size: 36rpx;
}

.no-address-text {
  font-size: 28rpx;
  color: var(--text-light);
}

.arrow-icon {
  color: var(--text-light);
  font-size: 28rpx;
  margin-left: auto;
}

/* 商品清单 */
.order-items-card {
  background: #fff;
  margin: 0 24rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: var(--shadow);
}

.card-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border);
}

.card-title-icon {
  font-size: 32rpx;
}

.order-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-qty {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 备注 */
.remark-card {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 0 24rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: var(--shadow);
  gap: 16rpx;
}

.remark-label {
  font-size: 26rpx;
  color: var(--text-primary);
  white-space: nowrap;
  font-weight: 500;
}

.remark-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
}

.remark-placeholder {
  color: #ccc;
}

/* 费用明细 */
.fee-card {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: var(--shadow);
}

.fee-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.fee-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.fee-value {
  font-size: 26rpx;
  color: var(--text-primary);
}

.fee-value.free {
  color: var(--green);
  font-size: 24rpx;
}

.total-row {
  border-top: 1rpx solid var(--border);
  margin-top: 12rpx;
  padding-top: 20rpx;
}

.total-row .fee-label {
  font-weight: 600;
  color: var(--text-primary);
}

/* 底部提交栏 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 20rpx 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}

.submit-total {
  display: flex;
  align-items: center;
}

.submit-total-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.submit-btn {
  background: linear-gradient(135deg, var(--green) 0%, var(--green-light) 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 64rpx;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(45, 106, 79, 0.3);
}

.submit-btn:active {
  transform: scale(0.97);
}
