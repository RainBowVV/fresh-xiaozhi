<!-- 订单列表页 -->
<view class="page">
  <!-- 状态标签栏 -->
  <view class="status-tabs">
    <view class="tab-item {{currentTab === -1 ? 'active' : ''}}" bindtap="switchTab" data-tab="-1">
      <text>全部</text>
    </view>
    <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-tab="0">
      <text>待付款</text>
    </view>
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-tab="1">
      <text>待发货</text>
    </view>
    <view class="tab-item {{currentTab === 4 ? 'active' : ''}}" bindtap="switchTab" data-tab="4">
      <text>已完成</text>
    </view>
    <view class="tab-item {{currentTab === 5 ? 'active' : ''}}" bindtap="switchTab" data-tab="5">
      <text>已取消</text>
    </view>
  </view>

  <!-- 订单列表 -->
  <scroll-view class="order-list" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="order-card" wx:for="{{orders}}" wx:key="id" bindtap="goOrderDetail" data-id="{{item.id}}">
      <!-- 订单头部 -->
      <view class="order-header">
        <text class="order-no">订单号：{{item.orderNo}}</text>
        <view class="header-right">
          <text wx:if="{{item.status === 0 && countdowns[item.id]}}" class="countdown">⏳ {{countdowns[item.id]}}</text>
          <text class="order-status status-{{item.status}}">{{statusMap[item.status]}}</text>
        </view>
      </view>

      <!-- 订单商品 -->
      <view class="order-items">
        <view class="order-item" wx:for="{{item.items}}" wx:for-item="prod" wx:key="id">
          <image class="item-image" src="{{prod.productImage}}" mode="aspectFill"></image>
          <view class="item-info">
            <text class="item-name">{{prod.productName}}</text>
            <view class="item-right">
              <view class="price price-sm">
                <text class="symbol">¥</text>
                <text class="amount">{{prod.price}}</text>
              </view>
              <text class="item-qty">x{{prod.quantity}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 订单底部 -->
      <view class="order-footer">
        <text class="order-time">{{item.createTime}}</text>
        <view class="order-total">
          <text>共{{item.totalCount}}件 合计：</text>
          <view class="price price-sm">
            <text class="symbol">¥</text>
            <text class="amount">{{item.totalAmount}}</text>
          </view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="order-actions">
        <view class="action-btn" wx:if="{{item.status === 0}}" catchtap="cancelOrder" data-id="{{item.id}}">
          <text>取消订单</text>
        </view>
        <view class="action-btn primary" wx:if="{{item.status === 0}}" catchtap="payOrder" data-id="{{item.id}}">
          <text>去支付</text>
        </view>
        <view class="action-btn" wx:if="{{item.status === 4 || item.status === 5}}" catchtap="deleteOrder" data-id="{{item.id}}">
          <text>删除订单</text>
        </view>
        <view class="action-btn primary" wx:if="{{item.status === 4 || item.status === 5}}" catchtap="reorder" data-id="{{item.id}}">
          <text>再来一单</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{orders.length === 0}}">
      <text class="icon">📋</text>
      <text class="text">暂无订单</text>
      <view class="btn-primary btn-sm" style="margin-top: 32rpx;" bindtap="goShopping">
        <text>去逛逛</text>
      </view>
    </view>

    <view style="height: 40rpx;"></view>
  </scroll-view>
</view>
