<!-- 购物车页面 -->
<view class="page">
  <!-- 未登录状态 -->
  <view class="empty-state" wx:if="{{!isLoggedIn}}">
    <text class="icon">🛒</text>
    <text class="text">登录后查看购物车</text>
    <view class="btn-primary btn-sm" style="margin-top: 32rpx;" bindtap="goLogin">
      <text>去登录</text>
    </view>
  </view>

  <!-- 空购物车 -->
  <view class="empty-state" wx:elif="{{cartItems.length === 0}}">
    <text class="icon">🛒</text>
    <text class="text">购物车空空如也</text>
    <text class="sub-text">去逛逛吧~</text>
    <view class="btn-primary btn-sm" style="margin-top: 32rpx;" bindtap="goShopping">
      <text>去逛逛</text>
    </view>
  </view>

  <!-- 购物车列表 -->
  <view class="cart-content" wx:else>
    <!-- 顶部操作栏 -->
    <view class="cart-header">
      <text class="cart-title">购物车</text>
      <view class="clear-btn" bindtap="clearCart">
        <text>清空购物车</text>
      </view>
    </view>

    <!-- 商品列表 -->
    <scroll-view class="cart-list" scroll-y scroll-top="{{scrollTop}}" enhanced show-scrollbar="{{false}}">
      <view class="cart-item" wx:for="{{cartItems}}" wx:key="productId">
        <view class="checkbox {{item.selected ? 'checked' : ''}}" bindtap="toggleSelect" data-index="{{index}}">
          <text wx:if="{{item.selected}}">✓</text>
        </view>
        <image class="item-image" src="{{item.productImage}}" mode="aspectFill" bindtap="goProductDetail" data-id="{{item.productId}}"></image>
        <view class="item-info">
          <text class="item-name" bindtap="goProductDetail" data-id="{{item.productId}}">{{item.productName}}</text>
          <view class="item-bottom">
            <view class="price price-sm">
              <text class="symbol">¥</text>
              <text class="amount">{{item.price}}</text>
            </view>
            <view class="qty-selector">
              <view class="qty-btn qty-btn-minus" bindtap="decreaseQty" data-index="{{index}}">
                <text>-</text>
              </view>
              <text class="qty-value">{{item.quantity}}</text>
              <view class="qty-btn qty-btn-plus" bindtap="increaseQty" data-index="{{index}}">
                <text>+</text>
              </view>
            </view>
          </view>
        </view>
        <view class="delete-btn" bindtap="deleteItem" data-index="{{index}}">
          <text>✕</text>
        </view>
      </view>
      <!-- 底部间距，避免被结算栏遮挡 -->
      <view style="height: 140rpx;"></view>
    </scroll-view>

    <!-- 底部结算栏 -->
    <view class="checkout-bar safe-bottom">
      <view class="checkout-left">
        <view class="select-info">
          <view class="checkbox {{isAllSelected ? 'checked' : ''}}" bindtap="toggleSelectAll">
            <text wx:if="{{isAllSelected}}">✓</text>
          </view>
          <text>全选</text>
        </view>
        <view class="total-info">
          <text class="total-label">合计：</text>
          <view class="price">
            <text class="symbol">¥</text>
            <text class="amount">{{totalAmount}}</text>
          </view>
        </view>
      </view>
      <view class="checkout-btn {{selectedCount > 0 ? '' : 'disabled'}}" bindtap="goCheckout">
        <text>结算({{selectedCount}})</text>
      </view>
    </view>
  </view>
</view>
