.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.msg-list {
  flex: 1;
  padding: 24rpx 28rpx 0;
  min-height: 0;
  box-sizing: border-box;
}

.msg-item {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}

.msg-item.user {
  justify-content: flex-end;
}

.msg-item.bot {
  justify-content: flex-start;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.bot-avatar {
  background: #e8f5e9;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.user-avatar {
  margin-left: 12rpx;
  overflow: hidden;
}

.bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-all;
}

.user-bubble {
  background: #2d6a4f;
  color: #fff;
  border-bottom-right-radius: 4rpx;
}

.bot-bubble {
  background: #fff;
  color: #333;
  border-bottom-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.bot-wrap {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  max-width: 80%;
}

.bot-wrap .bot-bubble {
  max-width: 100%;
}

/* 思考中 */
.thinking {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.thinking-text {
  font-size: 26rpx;
  color: #999;
}

.dots {
  display: flex;
  gap: 6rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  background: #999;
  border-radius: 50%;
  animation: dot-bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes dot-bounce {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1.2); }
}

/* 输入区 */
.input-bar {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  padding: 16rpx 28rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
  flex-shrink: 0;
}

.input-box {
  flex: 1;
  min-height: 72rpx;
  max-height: 200rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 18rpx 28rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.send-btn {
  background: #2d6a4f;
  color: #fff;
  font-size: 26rpx;
  padding: 0 24rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  flex-shrink: 0;
  text-align: center;
  min-width: 100rpx;
}

.send-btn.disabled {
  background: #b7d7c8;
  color: rgba(255,255,255,0.6);
}
